<?xml version="1.0" encoding="utf-8"?>
<!-- Pantalla de login con logo Loyola y botones de demo visibles. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="240dp"
            android:layout_height="80dp"
            android:layout_marginTop="32dp"
            android:adjustViewBounds="true"
            android:contentDescription="Logo Universidad Loyola"
            android:src="@drawable/logo_app" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/login_titulo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/azul_oscuro_ul" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="@string/login_subtitulo"
            android:textSize="14sp"
            android:textColor="#666666" />

        <EditText
            android:id="@+id/etUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/login_usuario"
            android:autofillHints="username"
            android:inputType="text"
            android:text="mgarcia" />

        <EditText
            android:id="@+id/etContrasenia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/login_contrasenia"
            android:autofillHints="password"
            android:inputType="textPassword"
            android:text="Loyola2026!" />

        <Button
            android:id="@+id/btnEntrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/login_entrar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/login_demo_titulo"
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="#666666" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <Button
                android:id="@+id/btnDemoAlumni"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/login_demo_alumni"
                android:textColor="@color/white"
                android:background="@drawable/bg_demo_button" />

            <Button
                android:id="@+id/btnDemoPdi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="@string/login_demo_pdi"
                android:textColor="@color/white"
                android:background="@drawable/bg_demo_button" />

            <Button
                android:id="@+id/btnDemoPtgas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:text="@string/login_demo_ptgas"
                android:textColor="@color/white"
                android:background="@drawable/bg_demo_button" />

            <Button
                android:id="@+id/btnDemoAdmin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/login_demo_admin"
                android:textColor="@color/white"
                android:background="@drawable/bg_demo_button" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
