<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF">

        <EditText
            android:id="@+id/etBusqueda"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="@string/buscar_hint"
            android:background="@drawable/bg_edittext_rounded"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnFiltros"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="@drawable/bg_button_rounded"
            android:contentDescription="@string/filtros_avanzados" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvInfoResultados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="#666666" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAlumni"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSinResultados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sin_resultados"
        android:textAlignment="center"
        android:padding="32dp"
        android:visibility="gone" />
</LinearLayout>
