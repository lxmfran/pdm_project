<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filtros_avanzados"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <EditText
            android:id="@+id/etFiltroTitulacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titulacion"
            android:inputType="text" />

        <EditText
            android:id="@+id/etFiltroPromocion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Promocion (anio)"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Facultad"
            android:layout_marginTop="8dp"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spFiltroFacultad"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Campus"
            android:layout_marginTop="8dp"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spFiltroCampus"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <EditText
            android:id="@+id/etFiltroCiudad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ciudad"
            android:inputType="text" />

        <EditText
            android:id="@+id/etFiltroTrabajo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Trabajo / empresa"
            android:inputType="text" />

        <EditText
            android:id="@+id/etFiltroHobbies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Hobbies"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnLimpiarFiltros"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/filtros_limpiar"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btnAplicarFiltros"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/filtros_aplicar" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
