<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Variante de tema para modo oscuro (paleta UL invertida) -->
    <style name="Base.Theme.Alumni" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/azul_claro_ul</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/azul_oscuro_ul</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/verde_ul</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/azul_oscuro_ul</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <item name="colorTertiary">@color/amarillo_ul</item>
        <item name="colorOnTertiary">@color/black</item>

        <item name="colorError">@color/rojo_ul</item>
        <item name="colorOnError">@color/white</item>

        <item name="android:colorBackground">#FF121212</item>
        <item name="colorSurface">#FF1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>
    </style>
</resources>
