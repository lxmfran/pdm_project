<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base de la app (modo claro) con paleta UL -->
    <style name="Base.Theme.Alumni" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/azul_oscuro_ul</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/azul_claro_ul</item>
        <item name="colorOnPrimaryContainer">@color/black</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/azul_claro_ul</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/verde_ul</item>
        <item name="colorOnSecondaryContainer">@color/black</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/amarillo_ul</item>
        <item name="colorOnTertiary">@color/black</item>

        <!-- Error -->
        <item name="colorError">@color/rojo_ul</item>
        <item name="colorOnError">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
    </style>

    <style name="Theme.Alumni" parent="Base.Theme.Alumni" />
</resources>
